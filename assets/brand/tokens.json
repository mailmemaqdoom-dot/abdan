{
  "$schema": "https://abdan.pages.dev/brand/tokens.schema.json",
  "brand": {
    "name": "ABDAN",
    "tagline": "Where devotion meets style.",
    "tagline_hero": "this time, the thought belongs to you. 💛",
    "website": "https://abdan.pages.dev",
    "founded": 2024
  },

  "colors": {
    "primary": {
      "emerald": {
        "value": "#023d3a",
        "name": "Emerald Green",
        "use": "Primary brand colour — CTA buttons, logo background, active states, dark surfaces"
      },
      "emerald_deep": {
        "value": "#012f2c",
        "name": "Emerald Deep",
        "use": "Darker variant — footers, pressed states, deep backgrounds"
      },
      "gold": {
        "value": "#c5a13b",
        "name": "Warm Gold",
        "use": "Accent colour — borders, icon mark, highlights, trust signals, gold CTAs in dark mode"
      },
      "cream": {
        "value": "#e6dfcb",
        "name": "Soft Cream",
        "use": "Muted backgrounds — card grounds, section dividers, secondary surfaces"
      },
      "ivory": {
        "value": "#f8f5ec",
        "name": "Ivory",
        "use": "Page background base — primary light surface"
      },
      "ivory_deep": {
        "value": "#efe8d8",
        "name": "Ivory Deep",
        "use": "Page gradient mid-point — warm depth without contrast"
      }
    },
    "text": {
      "ink": {
        "value": "#162f2d",
        "name": "Ink",
        "use": "Primary body text on light backgrounds"
      },
      "muted": {
        "value": "#5d6964",
        "name": "Muted",
        "use": "Secondary text — captions, descriptions, metadata"
      },
      "dim": {
        "value": "#7a8d89",
        "name": "Dim",
        "use": "Tertiary text — placeholders, disabled states"
      }
    },
    "transparent_gold": {
      "gold_10": "rgba(197, 161, 59, 0.10)",
      "gold_18": "rgba(197, 161, 59, 0.18)",
      "gold_28": "rgba(197, 161, 59, 0.28)",
      "gold_38": "rgba(197, 161, 59, 0.38)",
      "gold_60": "rgba(197, 161, 59, 0.60)"
    },
    "transparent_emerald": {
      "emerald_08": "rgba(2, 61, 58, 0.08)",
      "emerald_12": "rgba(2, 61, 58, 0.12)",
      "emerald_20": "rgba(2, 61, 58, 0.20)"
    },
    "never_use": ["#000000", "#ffffff", "any saturated or neon colour"]
  },

  "typography": {
    "fonts": {
      "calligraphy": {
        "family": "Abdan Calligraph",
        "fallbacks": ["Cormorant Garamond", "Georgia", "serif"],
        "weights": [400],
        "use": "Identity ONLY — wordmark, footer mark, loading screen. Never for product titles, navigation, UI, or body copy.",
        "file": "assets/fonts/AbdanCalligraph.woff2",
        "source": "Proprietary — provided by brand designer"
      },
      "editorial": {
        "family": "Libre Baskerville",
        "fallbacks": ["Baskerville", "Georgia", "serif"],
        "weights": [400, 700],
        "use": "Editorial surfaces — hero headlines, section titles, campaign narratives, promise band, story cards, testimonials. Weight 400 only for luxury restraint.",
        "source": "Google Fonts",
        "google_fonts_url": "https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap",
        "note": "Baskerville only has true weight 400 (regular) and 700 (bold). Any weight 500–600 renders as 700."
      },
      "body": {
        "family": "Open Sans",
        "fallbacks": ["system-ui", "sans-serif"],
        "weights": [300, 400, 500, 600],
        "use": "All operational UI — navigation, product titles, descriptions, buttons, forms, checkout, account, admin, metadata, labels.",
        "source": "Google Fonts",
        "google_fonts_url": "https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      },
      "supporting_editorial": {
        "family": "Cormorant Garamond",
        "fallbacks": ["Georgia", "serif"],
        "weights": [400, 500, 600],
        "weights_italic": [400],
        "use": "Supporting editorial italic — trust rail, editorial pull-quotes, accent moments. Fallback for Abdan Calligraph.",
        "source": "Google Fonts",
        "google_fonts_url": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      }
    },
    "scale": {
      "display":     { "value": "clamp(1.875rem, 5.5vw, 4.5rem)",  "px_range": "30–72px",  "use": "Hero h1" },
      "heading_xl":  { "value": "clamp(1.375rem, 3.5vw, 2.5rem)",  "px_range": "22–40px",  "use": "Section h2" },
      "heading_lg":  { "value": "clamp(1.25rem, 2.5vw, 1.875rem)", "px_range": "20–30px",  "use": "Smaller h2" },
      "heading_md":  { "value": "1.125rem",                         "px": "18px",           "use": "h3 / product titles" },
      "heading_sm":  { "value": "1.0625rem",                        "px": "17px",           "use": "Sub-headings" },
      "body_lg":     { "value": "1.0625rem",                        "px": "17px",           "use": "Hero body copy" },
      "body":        { "value": "0.9375rem",                        "px": "15px",           "use": "Standard body" },
      "body_sm":     { "value": "0.875rem",                         "px": "14px",           "use": "Secondary body, buttons" },
      "label":       { "value": "0.8125rem",                        "px": "13px",           "use": "Labels, navigation" },
      "micro":       { "value": "0.6875rem",                        "px": "11px",           "use": "Micro markers, badges" }
    },
    "line_height": {
      "tight":   1.1,
      "snug":    1.35,
      "normal":  1.7,
      "relaxed": 1.75,
      "loose":   1.95
    }
  },

  "spacing": {
    "container_max": "1160px",
    "section_padding_vertical": "clamp(4rem, 8vh, 7rem)",
    "section_padding_horizontal": "1.25rem"
  },

  "radius": {
    "2xl":  "2rem",
    "xl":   "1.75rem",
    "lg":   "1.6rem",
    "md":   "1.25rem",
    "sm":   "1rem",
    "xs":   "0.85rem",
    "pill": "999px"
  },

  "shadow": {
    "xs":   "0 2px 10px rgba(18, 31, 29, 0.04)",
    "sm":   "0 8px 24px rgba(18, 31, 29, 0.055)",
    "soft": "0 16px 40px rgba(18, 31, 29, 0.065)",
    "lift": "0 24px 58px rgba(18, 31, 29, 0.1)",
    "deep": "0 40px 100px rgba(18, 31, 29, 0.14)"
  },

  "logo": {
    "files": {
      "wordmark_full":      "assets/logo/abdan-wordmark-full.jpeg",
      "seal_dark":          "assets/logo/abdan-seal-dark.jpeg",
      "seal_light":         "assets/logo/abdan-seal-light.jpg",
      "icon_mark":          "assets/logo/abdan-icon-mark.jpeg",
      "business_card_h":    "assets/logo/abdan-business-card-h.jpeg",
      "business_card_info": "assets/logo/abdan-business-card-contact.png",
      "svg_mark":           "assets/logo/abdan-logo.svg",
      "favicon_svg":        "assets/favicon.svg",
      "site_icon":          "assets/abdan-icon.jpg"
    },
    "usage_rules": {
      "minimum_size_digital": "32px",
      "minimum_clear_space": "50% of logo mark height on all sides",
      "approved_on_backgrounds": ["Ivory #f8f5ec", "Emerald Green #023d3a", "White"],
      "never_do": [
        "Stretch or distort the mark",
        "Change the mark colours",
        "Place on busy photographic backgrounds",
        "Use Abdan Calligraph for body text or UI",
        "Use the wordmark below 120px wide"
      ]
    }
  },

  "brand_voice": {
    "tone": ["Warm", "Intimate", "Unhurried", "Confident", "Restrained"],
    "never": ["Pushy", "Algorithmic", "Generic", "Loud", "Transactional"],
    "core_value": "Luxury maturity: refinement, intentionality, emotional confidence, restraint, atmosphere, timelessness"
  }
}
